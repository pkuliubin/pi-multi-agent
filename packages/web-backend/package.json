{
	"name": "@earendil-works/pi-web-backend",
	"version": "0.0.0",
	"description": "Node bridge backend for Pi shared-state multi-agent Web UI",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"pi-web-backend": "dist/cli.js"
	},
	"files": ["dist"],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsx src/cli.ts",
		"start": "node dist/cli.js",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.75.5",
		"@earendil-works/pi-multi-agent": "^0.75.5",
		"@hono/node-server": "1.14.4",
		"hono": "4.8.2"
	},
	"devDependencies": {
		"@types/node": "22.19.19",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"keywords": ["ai", "agent", "multi-agent", "web", "backend"],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi-mono.git",
		"directory": "packages/web-backend"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
