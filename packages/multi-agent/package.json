{
	"name": "@earendil-works/pi-multi-agent",
	"version": "0.75.5",
	"description": "Multi-agent primitives for Pi agents",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
